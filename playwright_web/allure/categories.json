[
  {
    "name": "Falhas de localizacao de elemento (seletor invalido)",
    "matchedStatuses": ["broken", "failed"],
    "messageRegex": ".*(locator|getByRole|getByText|Timed out|waiting for selector).*"
  },
  {
    "name": "Erros de navegacao",
    "matchedStatuses": ["broken", "failed"],
    "messageRegex": ".*(page\\.goto|net::ERR|navigation).*"
  },
  {
    "name": "Falhas de assertion",
    "matchedStatuses": ["failed"],
    "messageRegex": ".*(expect|toHaveText|toBeVisible|toHaveURL|toEqual).*"
  },
  {
    "name": "Timeouts",
    "matchedStatuses": ["broken", "failed"],
    "messageRegex": ".*(Test timeout|TimeoutError|exceeded).*"
  }
]
