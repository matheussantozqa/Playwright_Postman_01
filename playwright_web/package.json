{
  "name": "playwright_web",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "playwright test --reporter=line,allure-playwright && npm run copy-meta",
    "test:ci": "playwright test --reporter=line,allure-playwright && npm run copy-meta",
    "inject-suites": "node scripts/inject-allure-suites.js allure-results",
    "copy-meta": "node scripts/copy-allure-meta.js allure-results",
    "report:generate": "npm run copy-meta && allure generate allure-results --clean -o allure-report",
    "report:open": "allure open allure-report",
    "clean": "rimraf allure-results allure-report playwright-report test-results"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.8.0",
    "allure-playwright": "^3.0.0",
    "rimraf": "^5.0.5"
  },
  "dependencies": {
    "allure-commandline": "^2.41.0"
  }
}
