    {
      "name": "ST-03 SQL INJECTION NO FILTRO DE BUSCA",
      "item": [
        {
          "name": "SQL INJECTION NO FILTRO DE BUSCA",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"SQL Injection UNION SELECT não retorna 500\", function () {\r",
                  "    pm.expect(pm.response.code).to.not.equal(500);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Retorna 200 com lista normal ou vazia\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "    const body = pm.response.json();\r",
                  "    pm.expect(body).to.be.an(\"array\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://restful-booker.herokuapp.com/booking?firstname=' UNION SELECT * FROM booking; --",
              "protocol": "https",
              "host": [
                "restful-booker",
                "herokuapp",
                "com"
              ],
              "path": [
                "booking"
              ],
              "query": [
                {
                  "key": "firstname",
                  "value": "' UNION SELECT * FROM booking; --"
