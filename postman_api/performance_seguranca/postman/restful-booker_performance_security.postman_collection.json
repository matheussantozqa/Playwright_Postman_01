    {
      "name": "PT-03 TEMPO DE RESPOSTA — CRIAR RESERVA",
      "item": [
        {
          "name": "TEMPO DE RESPOSTA — CRIAR RESERVA",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status é 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Tempo de resposta menor que 2000ms\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});",
                  "",
                  "pm.test(\"Body retorna objeto com bookingid\", function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property(\"bookingid\");",
                  "    pm.expect(body.bookingid).to.be.a(\"number\");",
                  "});",
                  "",
                  "pm.test(\"Body retorna os dados da reserva criada\", function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.booking).to.have.property(\"firstname\", \"John\");",
                  "    pm.expect(body.booking).to.have.property(\"lastname\", \"Doe\");",
                  "    pm.expect(body.booking).to.have.property(\"totalprice\", 150);",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
