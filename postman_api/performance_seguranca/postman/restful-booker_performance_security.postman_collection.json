    {
      "name": "ST-04 BRUTE FORCE EM POST /AUTH — RATE LIMITING",
      "item": [
        {
          "name": "BRUTE FORCE EM POST /AUTH — RATE LIMITING",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Verifica rate limiting ou bloqueio\", function () {\r",
                  "    const status = pm.response.code;\r",
                  "    pm.expect(status).to.be.oneOf([429, 403, 200]);\r",
                  "    \r",
                  "    if (status === 429) {\r",
                  "        console.log(\"Rate limiting aplicado - 429 Too Many Requests\");\r",
                  "    } else if (status === 403) {\r",
                  "        console.log(\"Conta bloqueada - 403 Forbidden\");\r",
                  "    } else if (status === 200) {\r",
                  "        const body = pm.response.json();\r",
                  "        console.log(\"Resposta: \" + JSON.stringify(body));\r",
                  "    }\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"username\": \"admin\",\r\n  \"password\": \"senhaerrada123\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "https://restful-booker.herokuapp.com/auth",
              "protocol": "https",
              "host": [
                "restful-booker",
                "herokuapp",
                "com"
              ],
              "path": [
                "auth"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "ST-05 EXPOSIÇÃO DE DADOS SENSÍVEIS NA RESPOSTA",
      "item": [
        {
          "name": "EXPOSIÇÃO DE DADOS SENSÍVEIS NA RESPOSTA",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Header X-Powered-By não está exposto\", function () {\r",
                  "    pm.expect(pm.response.headers.get(\"X-Powered-By\")).to.be.null;\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Header Server não expõe versão ou tecnologia\", function () {\r",
                  "    const server = pm.response.headers.get(\"Server\");\r",
                  "    if (server) {\r",
                  "        pm.expect(server).to.not.match(/apache\\/\\d/i);\r",
                  "        pm.expect(server).to.not.match(/nginx\\/\\d/i);\r",
                  "        pm.expect(server).to.not.match(/php\\/\\d/i);\r",
                  "    } else {\r",
                  "        pm.expect(server).to.be.null;\r",
                  "    }\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Body não contém campos sensíveis\", function () {\r",
                  "    const body = pm.response.json();\r",
                  "    pm.expect(body).to.not.have.property(\"password\");\r",
                  "    pm.expect(body).to.not.have.property(\"token\");\r",
                  "    pm.expect(body).to.not.have.property(\"hash\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://restful-booker.herokuapp.com/booking/4",
              "protocol": "https",
              "host": [
                "restful-booker",
                "herokuapp",
                "com"
              ],
              "path": [
                "booking",
                "4"
              ]
            }
          },
          "response": []
        }
      ]
