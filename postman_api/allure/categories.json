[
  {
    "name": "Falhas de autenticacao",
    "matchedStatuses": ["failed"],
    "messageRegex": ".*(401|403|token|auth).*"
  },
  {
    "name": "Erros de validacao de schema/dados",
    "matchedStatuses": ["failed"],
    "messageRegex": ".*(expected|to\\.eql|to\\.have\\.property|content-type).*"
  },
  {
    "name": "Status code inesperado",
    "matchedStatuses": ["failed"],
    "messageRegex": ".*(Status code|to\\.have\\.status).*"
  },
  {
    "name": "Tempo de resposta acima do esperado",
    "matchedStatuses": ["failed"],
    "messageRegex": ".*(below|responseTime|Tempo de resposta).*"
  },
  {
    "name": "Erros de infraestrutura / API indisponivel",
    "matchedStatuses": ["broken"],
    "messageRegex": ".*(ECONNREFUSED|ETIMEDOUT|ENOTFOUND|503|504|getaddrinfo).*"
  }
]
